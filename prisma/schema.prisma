generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Player {
  id       String  @id @default(cuid())
  name     String  @unique
  password String
  color    String? // custom hex color, null = use default
}

model Message {
  id        String   @id @default(cuid())
  from      String
  to        String
  body      String
  createdAt DateTime @default(now())
}

model Initiative {
  id        String   @id @default(cuid())
  name      String
  roll      Int
  isPlayer  Boolean  @default(true)
  isActive  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model InitiativeState {
  id        String   @id @default("singleton")
  round     Int      @default(1)
  isActive  Boolean  @default(false)
  phase     String   @default("idle") // "idle", "entry", "locked"
  updatedAt DateTime @updatedAt
}

model SeatingLock {
  id       String   @id @default("active")
  seats    String   // JSON array of 6 player names in seat order
  lockedBy String
  lockedAt DateTime @default(now())
}

// --- Messaging V2 ---

model Conversation {
  id        String   @id @default(cuid())
  type      String   // "dm" or "group"
  name      String?  // group name (null for DMs)
  emoji     String?  // custom emoji icon for groups
  members   String   // JSON array of player names
  createdBy String
  createdAt DateTime @default(now())
}

model MessageV2 {
  id             String   @id @default(cuid())
  conversationId String
  from           String
  body           String
  tag            String?  // "IC", "OOC", or null
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
}

model ConversationRead {
  id             String   @id @default(cuid())
  conversationId String
  playerName     String
  lastReadAt     DateTime @default(now())

  @@unique([conversationId, playerName])
}

model Pinboard {
  id             String   @id @default(cuid())
  conversationId String   @unique
  content        String   @default("")
  updatedAt      DateTime @updatedAt
  updatedBy      String?
}

// --- Push Notifications ---

model PushSubscription {
  id         String   @id @default(cuid())
  playerName String
  endpoint   String
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  @@unique([playerName, endpoint])
}

// --- Message Reactions ---

model MessageReaction {
  id         String   @id @default(cuid())
  messageId  String
  playerName String
  emoji      String
  createdAt  DateTime @default(now())

  @@unique([messageId, playerName, emoji])
  @@index([messageId])
}

// --- Games ---

model GameSession {
  id         String    @id @default(cuid())
  gameId     String
  status     String    @default("lobby") // "lobby", "active", "finished"
  difficulty String    @default("medium")
  timeLimit  Int       @default(0) // seconds, 0 = unlimited
  seed       Int?
  players    String    @default("[]") // JSON array of player names
  results    String    @default("[]") // JSON array of { playerName, score, completedAt, metadata }
  createdAt  DateTime  @default(now())
  startedAt  DateTime?
  endedAt    DateTime?
}

// --- Link Previews ---

model LinkPreview {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String?
  description String?
  imageUrl    String?
  domain      String
  fetchedAt   DateTime @default(now())
}

// --- Character Sheets ---

model CharacterSheet {
  id             String   @id @default(cuid())
  playerName     String   @unique
  characterName  String   @default("")
  level          Int      @default(1)
  movementSpeed  Int      @default(30)
  strength       Int      @default(10)
  dexterity      Int      @default(10)
  constitution   Int      @default(10)
  intelligence   Int      @default(10)
  wisdom         Int      @default(10)
  charisma       Int      @default(10)
  skills         String   @default("{}") // JSON: { skillName: { proficient: bool, expertise: bool } }
  updatedAt      DateTime @updatedAt
}
