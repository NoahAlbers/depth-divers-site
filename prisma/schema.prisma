generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Player {
  id       String @id @default(cuid())
  name     String @unique
  password String
}

model Message {
  id        String   @id @default(cuid())
  from      String
  to        String
  body      String
  createdAt DateTime @default(now())
}

model Initiative {
  id        String   @id @default(cuid())
  name      String
  roll      Int
  isPlayer  Boolean  @default(true)
  isActive  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model InitiativeState {
  id        String   @id @default("singleton")
  round     Int      @default(1)
  isActive  Boolean  @default(false)
  phase     String   @default("idle") // "idle", "entry", "locked"
  updatedAt DateTime @updatedAt
}

model SeatingLock {
  id       String   @id @default("active")
  seats    String   // JSON array of 6 player names in seat order
  lockedBy String
  lockedAt DateTime @default(now())
}
