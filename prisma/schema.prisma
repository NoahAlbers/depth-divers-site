generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Player {
  id       String @id @default(cuid())
  name     String @unique
  password String
}

model Message {
  id        String   @id @default(cuid())
  from      String
  to        String
  body      String
  createdAt DateTime @default(now())
}

model Initiative {
  id        String   @id @default(cuid())
  name      String
  roll      Int
  isPlayer  Boolean  @default(true)
  isActive  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model InitiativeState {
  id        String   @id @default("singleton")
  round     Int      @default(1)
  isActive  Boolean  @default(false)
  phase     String   @default("idle") // "idle", "entry", "locked"
  updatedAt DateTime @updatedAt
}

model SeatingLock {
  id       String   @id @default("active")
  seats    String   // JSON array of 6 player names in seat order
  lockedBy String
  lockedAt DateTime @default(now())
}

// --- Messaging V2 ---

model Conversation {
  id        String   @id @default(cuid())
  type      String   // "dm" or "group"
  name      String?  // group name (null for DMs)
  members   String   // JSON array of player names
  createdBy String
  createdAt DateTime @default(now())
}

model MessageV2 {
  id             String   @id @default(cuid())
  conversationId String
  from           String
  body           String
  tag            String?  // "IC", "OOC", or null
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
}

model ConversationRead {
  id             String   @id @default(cuid())
  conversationId String
  playerName     String
  lastReadAt     DateTime @default(now())

  @@unique([conversationId, playerName])
}

model Pinboard {
  id             String   @id @default(cuid())
  conversationId String   @unique
  content        String   @default("")
  updatedAt      DateTime @updatedAt
  updatedBy      String?
}
